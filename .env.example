APP_ENV=development
LOG_LEVEL=INFO

# Local development:
DATABASE_URL=sqlite:///data.db

# Online PostgreSQL example:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

SESSION_LIMIT_MINUTES=50
TASK_WORKER_ENABLED=true
TASK_SCAN_INTERVAL_SECONDS=60
ENABLE_DEBUG_ENDPOINTS=false
TESTING=false

# Auth / internal backend protection
AUTH_SECRET=change-me-to-a-long-random-secret
BACKEND_SHARED_TOKEN=change-me-to-a-long-random-token
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-use
SESSION_TTL_DAYS=7

# Password reset email
PASSWORD_RESET_TTL_MINUTES=30
PASSWORD_RESET_COOLDOWN_SECONDS=120
EMAIL_VERIFICATION_TTL_HOURS=24
TOKEN_RETENTION_DAYS=7
ACCOUNT_RATE_LIMIT_WINDOW_SECONDS=900
ACCOUNT_RATE_LIMIT_MAX_REQUESTS=5
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
APP_BASE_URL=http://localhost:3000

# Real Dify E2E tests. Leave disabled for normal test runs.
RUN_DIFY_E2E=false
# DIFY_API_KEY=
BACKEND_URL=https://ai-assistant-psy-mvp.619569391.workers.dev
DIFY_API_BASE=https://api.dify.ai/v1
DIFY_E2E_TIMEOUT_SECONDS=60
